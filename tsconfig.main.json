{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "rootDir": "src",
    "noImplicitAny": false
  },
  "include": ["src/main.ts", "src/preload.ts", "src/lib/**/*.ts"],
  "exclude": ["src/lib/electronAPI.ts"]
}
