{
  "name": "echo-developer-studio",
  "productName": "ECHO Developer Studio",
  "version": "0.1.0",
  "description": "The official command center for building and shipping the ECHO Platform.",
  "main": "dist/main.cjs",
  "author": {
    "name": "ECHO Labs",
    "email": "dev@echolabs.dev"
  },
  "homepage": "https://echolabs.dev",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"set ELECTRON_RUN_AS_NODE= && wait-on tcp:127.0.0.1:5173 && electron .\"",
    "dev:win": "concurrently \"npm run dev:vite\" \"powershell -Command $env:ELECTRON_RUN_AS_NODE=$null; Start-Sleep -Seconds 3; electron .\"",
    "dev:vite": "vite",
    "build": "npm run clean:dist && tsc -p tsconfig.main.json && vite build --config vite.main.config.ts && vite build && npm run clean:tsc",
    "build:electron": "npm run build",
    "clean:dist": "powershell -Command \"if (Test-Path dist) { Remove-Item -Recurse -Force dist }\"",
    "clean:tsc": "powershell -Command \"if (Test-Path dist/lib) { Remove-Item -Recurse -Force dist/lib }; if (Test-Path dist/main.js) { Remove-Item -Force dist/main.js }\"",
    "dist": "npm run build:electron && electron-builder",
    "dist:win": "npm run build:electron && electron-builder --win",
    "dist:win:nsis": "npm run build:electron && electron-builder --win nsis",
    "dist:win:portable": "npm run build:electron && electron-builder --win portable",
    "dist:win:zip": "npm run build:electron && electron-builder --win zip",
    "dist:mac": "npm run build:electron && electron-builder --mac",
    "dist:linux": "npm run build:electron && electron-builder --linux",
    "dist:publish": "npm run dist:publish:internal",
    "dist:publish:public": "npm run build:electron && electron-builder --config electron-builder.public.yml --publish always",
    "dist:publish:internal": "npm run build:electron && electron-builder --config electron-builder.yml --publish always",
    "prerelease:check": "node scripts/check-windows-prereqs.js",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run",
    "preview": "vite preview"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@types/uuid": "^10.0.0",
    "chokidar": "^3.6.0",
    "clsx": "^2.1.0",
    "electron-log": "^5.4.4",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9",
    "framer-motion": "^12.40.0",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.22.0",
    "tailwind-merge": "^2.2.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "wait-on": "^7.2.0"
  }
}
